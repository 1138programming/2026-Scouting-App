<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:foregroundTint="@color/black"
    android:clickable="true"
    tools:context="fragments.SettingsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/mainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/off_white"
            android:textSize="96sp"
            android:textStyle="normal|bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/fieldOrientationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="50dp"
            android:layout_marginTop="60dp"
            android:text="@string/field_orientation_title"
            android:textColor="@color/off_white"
            android:textSize="45sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mainTitle" />

        <Button
            android:id="@+id/flipButton"
            android:layout_width="160sp"
            android:layout_height="80sp"
            android:text="@string/flip_button"
            android:textColor="@color/background_default"
            android:textSize="32sp"
            app:layout_constraintBottom_toBottomOf="@+id/fieldOrientationTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/fieldOrientationTitle"
            app:layout_constraintTop_toTopOf="@+id/fieldOrientationTitle" />


        <ImageView
            android:id="@+id/imageView"
            android:layout_width="500dp"
            android:layout_height="wrap_content"
            android:src="@drawable/frcfield_blue_red"
            app:layout_constraintBottom_toTopOf="@+id/handednessTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fieldOrientationTitle" />

        <ImageView
            android:id="@+id/reversedImage"
            android:layout_width="500dp"
            android:layout_height="wrap_content"
            android:src="@drawable/frcfield_red_blue"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@+id/handednessTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fieldOrientationTitle" />

        <TextView
            android:id="@+id/handednessTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="350dp"
            android:text="@string/handedness_title"
            android:textColor="@color/off_white"
            android:textSize="45sp"
            app:layout_constraintStart_toStartOf="@+id/fieldOrientationTitle"
            app:layout_constraintTop_toBottomOf="@+id/fieldOrientationTitle" />

        <RadioGroup
            android:id="@+id/hand_switch"
            android:layout_width="300dp"
            android:layout_height="40dp"
            android:background="@drawable/toggle_background"
            android:checkedButton="@+id/right_hand"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@+id/handednessTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/handednessTitle"
            app:layout_constraintTop_toTopOf="@+id/handednessTitle">


            <RadioButton
                android:id="@+id/left_hand"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginTop="1dp"
                android:layout_marginStart="1dp"
                android:layout_marginBottom="1dp"
                android:layout_weight="1"
                android:background="@drawable/toggle_background_orange"
                android:button="@null"
                android:gravity="center"
                android:text="@string/left_title"
                android:textColor="@drawable/toggle_text_orange"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/right_hand"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="1dp"
                android:layout_marginTop="1dp"
                android:layout_marginBottom="1dp"
                android:layout_weight="1"
                android:background="@drawable/toggle_background_orange"
                android:button="@null"
                android:gravity="center"
                android:text="@string/right_title"
                android:textColor="@drawable/toggle_text_orange"
                android:textSize="20sp" />
        </RadioGroup>

        <Button
            android:id="@+id/closeMenu"
            android:layout_width="220sp"
            android:layout_height="120sp"
            android:layout_marginBottom="10dp"
            android:text="@string/close_settings"
            android:textColor="@color/background_default"
            android:textSize="48sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
